{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-git-workspace",
  "name": {
    "en": "Git Workspace",
    "ko": "\uae43 \uc6cc\ud06c\uc2a4\ud398\uc774\uc2a4"
  },
  "version": "0.0.1",
  "description": {
    "en": "One-shot worktree workspaces: a branch and worktree, its own window with a terminal at the worktree, and reclaim when done. Branches and commits survive close.",
    "ko": "\uc6d0\uc0f7 \uc6cc\ud06c\ud2b8\ub9ac \uc6cc\ud06c\uc2a4\ud398\uc774\uc2a4 \u2014 \ube0c\ub79c\uce58\uc640 \uc6cc\ud06c\ud2b8\ub9ac, \uc6cc\ud06c\ud2b8\ub9ac\ub97c cwd \ub85c \ud558\ub294 \uc804\uc6a9 \ucc3d\uacfc \ud130\ubbf8\ub110, \uc644\ub8cc \uc2dc \ud68c\uc218. \ub2eb\uc544\ub3c4 \ube0c\ub79c\uce58\uc640 \ucee4\ubc0b\uc740 \uc874\uc18d."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "commands",
    "commands:destructive",
    "data"
  ],
  "contributes": {
    "commands": [
      {
        "name": "worktree.open",
        "title": {
          "en": "Open a worktree workspace",
          "ko": "\uc6cc\ud06c\ud2b8\ub9ac \uc6cc\ud06c\uc2a4\ud398\uc774\uc2a4 \uc5f4\uae30"
        }
      },
      {
        "name": "worktree.close",
        "title": {
          "en": "Close a worktree workspace",
          "ko": "\uc6cc\ud06c\ud2b8\ub9ac \uc6cc\ud06c\uc2a4\ud398\uc774\uc2a4 \ub2eb\uae30"
        }
      },
      {
        "name": "worktree.list",
        "title": {
          "en": "List worktree workspaces",
          "ko": "\uc6cc\ud06c\ud2b8\ub9ac \uc6cc\ud06c\uc2a4\ud398\uc774\uc2a4 \ubaa9\ub85d"
        }
      }
    ],
    "views": [
      {
        "id": "view",
        "title": {
          "en": "Workspaces",
          "ko": "\uc6cc\ud06c\uc2a4\ud398\uc774\uc2a4"
        },
        "icon": "\u2387",
        "placements": [
          "sidebar-right",
          "content"
        ],
        "defaultPlacement": "sidebar-right",
        "status": [
          "loading",
          "empty",
          "active",
          "error"
        ]
      }
    ],
    "nodes": [
      {
        "id": "refresh",
        "description": {
          "en": "Refresh button (reloads the workspace list)",
          "ko": "\uc0c8\ub85c\uace0\uce68 \ubc84\ud2bc(\uc6cc\ud06c\uc2a4\ud398\uc774\uc2a4 \ubaa9\ub85d \uc7ac\ub85c\ub4dc)"
        }
      },
      {
        "id": "row",
        "description": {
          "en": "Workspace row (click = focus its window). data-node=\"row/<slug>\"",
          "ko": "\uc6cc\ud06c\uc2a4\ud398\uc774\uc2a4 \ud589(\ud074\ub9ad=\ucc3d \ud3ec\ucee4\uc2a4). data-node=\"row/<\uc2ac\ub7ec\uadf8>\""
        }
      },
      {
        "id": "close",
        "description": {
          "en": "Per-row close button (reclaims the worktree and window). data-node=\"close/<slug>\"",
          "ko": "\ud589\ubcc4 \ub2eb\uae30 \ubc84\ud2bc(\uc6cc\ud06c\ud2b8\ub9ac\u00b7\ucc3d \ud68c\uc218). data-node=\"close/<\uc2ac\ub7ec\uadf8>\""
        }
      }
    ]
  },
  "consumes": [
    {
      "id": "soksak-spec-plugin-git",
      "range": "0.0.1"
    }
  ]
}
